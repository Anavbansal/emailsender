# Gmail credentials
GMAIL_USER=your_gmail@gmail.com
GMAIL_PASS=your_16_char_app_password

# Gmail OAuth (for Inbox / Gmail API)
GOOGLE_CLIENT_ID=your_client_id
GOOGLE_CLIENT_SECRET=your_client_secret
GOOGLE_REDIRECT_URI=https://your-render-app.onrender.com/api/gmail/callback

PORT=5000

# Public URL (VERY IMPORTANT for tracking pixel)
BASE_URL=https://your-render-app.onrender.com

# Optional
GOOGLE_SHEET_ID=your_sheet_id
SHEET_TAB=Contacts
JOOBLE_API_KEY=your_key
HUNTER_API_KEY=your_key
